<header
  class="site-header fixed top-0 left-0 right-0 z-50 h-16 px-6 md:px-8 grid grid-cols-3 items-center bg-black text-white border-b border-transparent transition-[background,color,border-color] duration-300"
  data-template="{{ template.name }}"
>

  {%- comment -%} ── Left: hamburger (mobile) / nav (desktop) ── {%- endcomment -%}
  <div class="flex items-center">

    <button
      id="menu-toggle"
      type="button"
      aria-label="{{ 'header.menu_open' | t }}"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-label-open="{{ 'header.menu_open' | t }}"
      data-label-close="{{ 'header.menu_close' | t }}"
      class="md:hidden flex flex-col justify-center gap-[5px] text-current bg-transparent border-0 cursor-pointer p-0"
    >
      <span class="hamburger-line block w-5 h-[1.5px] bg-current transition-all duration-300 origin-center"></span>
      <span class="hamburger-line block w-5 h-[1.5px] bg-current transition-all duration-300 origin-center"></span>
      <span class="hamburger-line block w-5 h-[1.5px] bg-current transition-all duration-300 origin-center"></span>
    </button>

    <nav class="hidden md:flex items-center gap-8" aria-label="{{ 'general.accessibility.navigation' | t }}">
      {%- for link in section.settings.menu.links -%}
        <a
          href="{{ link.url }}"
          class="text-[10px] uppercase tracking-[0.3em] font-normal text-current no-underline transition-opacity duration-200 hover:opacity-40"
          {%- if link.active %} aria-current="page"{% endif %}
        >
          {{- link.title -}}
        </a>
      {%- endfor -%}
    </nav>

  </div>

  {%- comment -%} ── Center: logo ── {%- endcomment -%}
  <div class="flex justify-center">
    <a
      href="{{ routes.root_url }}"
      class="text-xl font-bold uppercase tracking-[0.5em] text-current no-underline transition-opacity duration-200 hover:opacity-70"
      aria-label="{{ shop.name }}"
    >
      Clottius
    </a>
  </div>

  {%- comment -%} ── Right: icons ── {%- endcomment -%}
  <div class="flex items-center justify-end gap-5">

    <button
      id="search-toggle"
      type="button"
      aria-label="{{ 'search.title' | t }}"
      aria-expanded="false"
      aria-controls="search-drawer"
      class="flex items-center justify-center text-current bg-transparent border-0 cursor-pointer p-0 transition-opacity duration-200 hover:opacity-40"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/>
        <path d="m21 21-4.35-4.35"/>
      </svg>
    </button>

    <button
      id="open-cart"
      type="button"
      aria-label="{{ 'cart.title' | t }}"
      class="relative flex items-center justify-center text-current bg-transparent border-0 cursor-pointer p-0 transition-opacity duration-200 hover:opacity-40"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
      {%- if cart.item_count > 0 -%}
        <span
          id="cart-count"
          class="absolute -top-1.5 -right-2 w-[18px] h-[18px] bg-white text-black text-[9px] font-semibold rounded-full flex items-center justify-center pointer-events-none transition-[background,color] duration-300"
        >
          {{- cart.item_count -}}
        </span>
      {%- endif -%}
    </button>

  </div>
</header>

<div
  id="mobile-menu"
  class="fixed inset-0 z-40 pointer-events-none opacity-0 transition-opacity duration-500"
  aria-hidden="true"
>
  <div class="absolute inset-0 bg-black/70 backdrop-blur-2xl flex flex-col px-6 pt-24 pb-12">

    <nav class="flex flex-col gap-8" aria-label="{{ 'general.accessibility.navigation' | t }}">
      {%- for link in section.settings.menu.links -%}
        <a
          href="{{ link.url }}"
          class="text-[11px] uppercase tracking-[0.4em] font-normal text-white no-underline transition-opacity duration-200 hover:opacity-40"
          {%- if link.active %} aria-current="page"{% endif %}
        >
          {{- link.title -}}
        </a>
      {%- endfor -%}
    </nav>

    <div class="mt-auto flex flex-col gap-5">
      <div class="w-6 h-px bg-white/20 mb-1"></div>
      <a
        href="{{ routes.account_url }}"
        class="text-[9px] uppercase tracking-[0.4em] font-normal text-white no-underline opacity-60 transition-opacity duration-200 hover:opacity-100"
      >
        {{- 'header.account' | t -}}
      </a>
      <a
        href="/pages/contact"
        class="text-[9px] uppercase tracking-[0.4em] font-normal text-white no-underline opacity-60 transition-opacity duration-200 hover:opacity-100"
      >
        {{- 'header.contact' | t -}}
      </a>
    </div>

  </div>
</div>

<div
  id="search-drawer"
  class="fixed inset-0 z-[60] pointer-events-none opacity-0 transition-opacity duration-500"
  aria-hidden="true"
  role="dialog"
  aria-label="{{ 'search.title' | t }}"
>
  <div class="absolute inset-0 bg-black/80 backdrop-blur-2xl flex flex-col items-center px-6 pt-28">

    <button
      id="search-close"
      type="button"
      aria-label="{{ 'general.accessibility.close' | t }}"
      class="absolute top-[1.35rem] right-6 flex items-center gap-2 text-[9px] uppercase tracking-[0.3em] text-white/50 bg-transparent border-0 cursor-pointer p-0 transition-opacity duration-200 hover:opacity-100"
    >
      <span>esc</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <form
      action="{{ routes.search_url }}"
      method="get"
      class="w-full max-w-lg"
      role="search"
    >
      <input type="hidden" name="type" value="product">
      <div class="relative border-b border-white/30 pb-3">
        <input
          id="search-input"
          type="search"
          name="q"
          autocomplete="off"
          placeholder="{{ 'search.placeholder' | t }}"
          class="search-field w-full bg-transparent text-white text-[11px] uppercase tracking-[0.4em] border-0 outline-none p-0 pr-7"
          aria-label="{{ 'search.title' | t }}"
        >
        <div id="search-spinner" class="absolute right-0 top-1/2 -translate-y-1/2 hidden">
          <svg class="animate-spin" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
          </svg>
        </div>
      </div>
    </form>

    <ul
      id="search-results"
      class="w-full max-w-lg mt-8 flex flex-col gap-px"
      role="listbox"
      aria-label="{{ 'search.title' | t }}"
    ></ul>

  </div>
</div>

{% stylesheet %}
  /* Scroll state */
  .site-header.is-scrolled {
    background: #fff;
    color: #000;
    border-bottom-color: #f3f4f6;
  }

  .site-header.is-scrolled #cart-count {
    background: #000;
    color: #fff;
  }

  /* Hamburger → X animation */
  .menu-is-open .hamburger-line:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .menu-is-open .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .menu-is-open .hamburger-line:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* Mobile drawer open state */
  .menu-is-open #mobile-menu {
    pointer-events: auto;
    opacity: 1;
  }

  /* Prevent scroll while menu is open */
  body.menu-is-open {
    overflow: hidden;
  }

  /* Search drawer open state */
  .search-is-open #search-drawer {
    pointer-events: auto;
    opacity: 1;
  }

  body.search-is-open {
    overflow: hidden;
  }

  /* Search input placeholder */
  .search-field::placeholder {
    text-transform: uppercase;
    letter-spacing: 0.4em;
    color: rgba(255, 255, 255, 0.3);
  }

  /* Hide browser default clear button on search inputs */
  .search-field::-webkit-search-cancel-button {
    display: none;
  }

  /* Search result items */
  .search-result-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0;
    text-decoration: none;
    color: white;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    transition: opacity 0.2s;
  }

  .search-result-item:hover {
    opacity: 0.6;
  }

  .search-result-img {
    width: 44px;
    height: 44px;
    object-fit: cover;
    flex-shrink: 0;
    background: rgba(255,255,255,0.05);
  }

  .search-result-title {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.35em;
    font-weight: 400;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    const header        = document.querySelector('.site-header');
    const menuToggle    = document.getElementById('menu-toggle');
    const mobileMenu    = document.getElementById('mobile-menu');
    const searchToggle  = document.getElementById('search-toggle');
    const searchDrawer  = document.getElementById('search-drawer');
    const searchClose   = document.getElementById('search-close');
    const searchInput   = document.getElementById('search-input');
    const searchResults = document.getElementById('search-results');
    const searchSpinner = document.getElementById('search-spinner');

    if (!header) return;

    // ── Scroll state ──────────────────────────────────────
    const isHomepage = header.dataset.template === 'index';

    function updateScroll(animate) {
      const shouldScroll = !isHomepage || window.scrollY > 50;
      if (!animate) header.style.transition = 'none';
      header.classList.toggle('is-scrolled', shouldScroll);
      if (!animate) { header.offsetHeight; header.style.transition = ''; }
    }

    updateScroll(false);
    window.addEventListener('scroll', function () { updateScroll(true); }, { passive: true });

    // ── Mobile menu ───────────────────────────────────────
    function openMenu() {
      document.body.classList.add('menu-is-open');
      menuToggle.setAttribute('aria-expanded', 'true');
      menuToggle.setAttribute('aria-label', menuToggle.dataset.labelClose);
      mobileMenu.setAttribute('aria-hidden', 'false');
    }

    function closeMenu() {
      document.body.classList.remove('menu-is-open');
      menuToggle.setAttribute('aria-expanded', 'false');
      menuToggle.setAttribute('aria-label', menuToggle.dataset.labelOpen);
      mobileMenu.setAttribute('aria-hidden', 'true');
    }

    if (menuToggle) {
      menuToggle.addEventListener('click', function () {
        document.body.classList.contains('menu-is-open') ? closeMenu() : openMenu();
      });
    }

    // ── Search drawer ─────────────────────────────────────
    function openSearch() {
      document.body.classList.add('search-is-open');
      searchDrawer.setAttribute('aria-hidden', 'false');
      searchToggle.setAttribute('aria-expanded', 'true');
      setTimeout(function () { searchInput.focus(); }, 50);
    }

    function closeSearch() {
      document.body.classList.remove('search-is-open');
      searchDrawer.setAttribute('aria-hidden', 'true');
      searchToggle.setAttribute('aria-expanded', 'false');
      searchInput.value = '';
      searchResults.innerHTML = '';
    }

    if (searchToggle) {
      searchToggle.addEventListener('click', openSearch);
    }

    if (searchClose) {
      searchClose.addEventListener('click', closeSearch);
    }

    // ── Predictive search ─────────────────────────────────
    var debounceTimer;

    function renderResults(products) {
      if (!products.length) {
        searchResults.innerHTML = '<li class="text-[9px] uppercase tracking-[0.35em] text-white/40 py-4">No results</li>';
        return;
      }

      searchResults.innerHTML = products.map(function (product) {
        var img = product.featured_image
          ? '<img class="search-result-img" src="' + product.featured_image.url + '" alt="" loading="lazy">'
          : '<div class="search-result-img"></div>';

        return '<li role="option">'
          + '<a href="' + product.url + '" class="search-result-item">'
          + img
          + '<span class="search-result-title">' + product.title + '</span>'
          + '</a>'
          + '</li>';
      }).join('');
    }

    if (searchInput) {
      searchInput.addEventListener('input', function () {
        var query = searchInput.value.trim();

        clearTimeout(debounceTimer);
        searchResults.innerHTML = '';

        if (query.length < 2) {
          searchSpinner.classList.add('hidden');
          return;
        }

        searchSpinner.classList.remove('hidden');

        debounceTimer = setTimeout(function () {
          fetch('/search/suggest.json?q=' + encodeURIComponent(query) + '&resources[type]=product&resources[limit]=6')
            .then(function (res) { return res.json(); })
            .then(function (data) {
              searchSpinner.classList.add('hidden');
              var products = (data.resources && data.resources.results && data.resources.results.products) || [];
              renderResults(products);
            })
            .catch(function () {
              searchSpinner.classList.add('hidden');
            });
        }, 300);
      });
    }

    // ── Escape key ────────────────────────────────────────
    document.addEventListener('keydown', function (e) {
      if (e.key !== 'Escape') return;
      if (document.body.classList.contains('search-is-open')) {
        closeSearch();
      } else {
        closeMenu();
      }
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
