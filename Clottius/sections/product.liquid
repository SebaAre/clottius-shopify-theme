<section class="bg-white px-4 py-12 md:px-6 md:py-20">
  <div class="max-w-6xl mx-auto">

    <div class="flex flex-col md:flex-row md:gap-12 lg:gap-20">

      {{- '<!-- Images -->' -}}
      <div class="w-full md:w-1/2">
        {% if product.images.size > 0 %}
          <div class="aspect-[3/4] overflow-hidden bg-[#f5f5f5] w-full">
            {{ product.featured_image | image_url: width: 1200 | image_tag:
              alt: product.title,
              class: 'w-full h-full object-cover'
            }}
          </div>
          {% if product.images.size > 1 %}
            <div class="grid grid-cols-4 gap-2 mt-2">
              {% for image in product.images %}
                <div class="aspect-square overflow-hidden bg-[#f5f5f5] cursor-pointer">
                  {{ image | image_url: width: 300 | image_tag:
                    alt: product.title,
                    class: 'w-full h-full object-cover hover:opacity-70 transition-opacity duration-200'
                  }}
                </div>
              {% endfor %}
            </div>
          {% endif %}
        {% endif %}
      </div>

      {{- '<!-- Info + Form -->' -}}
      <div class="w-full md:w-1/2 mt-8 md:mt-0 flex flex-col">

        <p class="text-[10px] tracking-[0.25em] uppercase text-gray-400 mb-2">{{ product.type | default: product.vendor }}</p>
        <h1 class="text-sm tracking-[0.2em] uppercase font-medium text-black leading-relaxed">{{ product.title }}</h1>

        <div class="mt-3 flex items-baseline gap-3">
          {% assign current_variant = product.selected_or_first_available_variant %}
          {% if current_variant.compare_at_price > current_variant.price %}
            <span class="text-xs tracking-widest text-gray-400 line-through">{{ current_variant.compare_at_price | money }}</span>
            <span class="text-sm tracking-widest text-black">{{ current_variant.price | money }}</span>
          {% else %}
            <span class="text-sm tracking-widest text-black">{{ current_variant.price | money }}</span>
          {% endif %}
        </div>

        {% if product.description != blank %}
          <div class="mt-6 text-xs text-gray-500 leading-relaxed tracking-wide border-t border-gray-100 pt-6">
            {{ product.description }}
          </div>
        {% endif %}

        {% form 'product', product %}
          <div class="mt-8 flex flex-col gap-4">

            {% if product.variants.size > 1 %}
              <div class="flex flex-col gap-1.5">
                <label class="text-[10px] tracking-[0.2em] uppercase text-gray-400" for="variant-select">
                  {{ 'products.variant' | t | default: 'Option' }}
                </label>
                <select
                  id="variant-select"
                  name="id"
                  class="w-full border border-gray-200 bg-white text-xs tracking-widest uppercase px-4 py-3 focus:outline-none focus:border-black transition-colors duration-200"
                >
                  {% for variant in product.variants %}
                    <option
                      value="{{ variant.id }}"
                      {% unless variant.available %}disabled{% endunless %}
                      {% if variant == current_variant %}selected{% endif %}
                    >
                      {{ variant.title }}{% unless variant.available %} — Sold out{% endunless %}
                    </option>
                  {% endfor %}
                </select>
              </div>
            {% else %}
              <input type="hidden" name="id" value="{{ current_variant.id }}">
            {% endif %}

            <div class="flex flex-col gap-1.5">
              <label class="text-[10px] tracking-[0.2em] uppercase text-gray-400" for="quantity-input">
                {{ 'cart.quantity' | t | default: 'Quantity' }}
              </label>
              <div class="flex items-center border border-gray-200 w-28">
                <button type="button" class="w-10 h-10 flex items-center justify-center text-black hover:bg-gray-50 transition-colors duration-200 select-none" onclick="const q=this.nextElementSibling;if(q.value>1)q.value=parseInt(q.value)-1">−</button>
                <input
                  id="quantity-input"
                  type="number"
                  name="quantity"
                  value="1"
                  min="1"
                  class="w-full h-10 text-center text-xs tracking-widest border-x border-gray-200 bg-white focus:outline-none"
                >
                <button type="button" class="w-10 h-10 flex items-center justify-center text-black hover:bg-gray-50 transition-colors duration-200 select-none" onclick="const q=this.previousElementSibling;q.value=parseInt(q.value)+1">+</button>
              </div>
            </div>

            <div class="flex flex-col gap-3 mt-2">
              {% if current_variant.available %}
                <button type="submit" class="w-full bg-black text-white text-[10px] tracking-[0.3em] uppercase py-4 hover:bg-gray-900 transition-colors duration-200">
                  Add to cart
                </button>
              {% else %}
                <button type="button" disabled class="w-full bg-gray-100 text-gray-400 text-[10px] tracking-[0.3em] uppercase py-4 cursor-not-allowed">
                  Sold out
                </button>
              {% endif %}
              {{ form | payment_button }}
            </div>

          </div>
        {% endform %}

      </div>
    </div>

  </div>
</section>

{% stylesheet %}
  /* Hide native number input spinners */
  #quantity-input::-webkit-outer-spin-button,
  #quantity-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  #quantity-input {
    -moz-appearance: textfield;
  }

  .shopify-payment-button {
    margin-top: 0;
  }

  .shopify-payment-button__button {
    border-radius: 0 !important;
    font-size: 0.625rem !important;
    letter-spacing: 0.3em !important;
    text-transform: uppercase !important;
    font-family: inherit !important;
    min-height: unset !important;
    padding: 1rem !important;
  }

  .shopify-payment-button__button--unbranded {
    background-color: #fff !important;
    color: #000 !important;
    border: 1px solid #000 !important;
  }

  .shopify-payment-button__button--unbranded:hover {
    background-color: #000 !important;
    color: #fff !important;
  }

  /* Branded buttons (Apple Pay, Google Pay, etc.) keep their brand colors
     but get square corners and consistent sizing */
  .shopify-payment-button__button--branded {
    border-radius: 0 !important;
  }

  .shopify-payment-button__more-options {
    font-size: 0.6rem !important;
    letter-spacing: 0.15em !important;
    text-transform: uppercase !important;
    color: rgba(0, 0, 0, 0.4) !important;
    font-family: inherit !important;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.product",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
