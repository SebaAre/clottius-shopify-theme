<section class="bg-white py-16 px-4 md:py-24 md:px-6">
  <div class="max-w-6xl mx-auto">

    <div class="flex items-end justify-between mb-8 md:mb-12">
      <h2 class="text-[10px] font-medium tracking-[0.3em] uppercase text-black">New Arrivals</h2>
      <a href="/collections/all" class="text-[10px] tracking-[0.2em] uppercase border-b border-black pb-0.5 hover:opacity-50 transition-opacity duration-200">
        Shop all
      </a>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-x-3 gap-y-10 md:gap-x-5 md:gap-y-14">
      {% for product in collections.all.products limit: 6 %}
        <a href="{{ product.url }}" class="group flex flex-col">

          <div class="relative overflow-hidden bg-[#f5f5f5] w-full aspect-[3/4]">
            {% if product.featured_image %}
              {{ product.featured_image | image_url: width: 800 | image_tag:
                alt: product.title,
                class: 'w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.04]'
              }}
            {% else %}
              <div class="w-full h-full flex items-center justify-center">
                <span class="text-[10px] tracking-widest uppercase text-gray-400">No image</span>
              </div>
            {% endif %}

            {% unless product.available %}
              <span class="absolute top-2 left-2 bg-black text-white text-[9px] tracking-[0.15em] uppercase px-2 py-1">
                Sold out
              </span>
            {% endunless %}

            {% if product.compare_at_price > product.price %}
              <span class="absolute top-2 right-2 bg-white text-black text-[9px] tracking-[0.15em] uppercase px-2 py-1 border border-black">
                Sale
              </span>
            {% endif %}

            <div class="hidden md:block absolute inset-x-0 bottom-0 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-out bg-black">
              <span class="block text-center text-white text-[10px] tracking-[0.25em] uppercase py-3">
                View product
              </span>
            </div>
          </div>

          <div class="mt-3 md:mt-4">
            <h3 class="text-[10px] md:text-xs tracking-[0.15em] uppercase text-black leading-snug">{{ product.title }}</h3>
            <div class="mt-1">
              {% if product.compare_at_price > product.price %}
                <span class="text-[10px] md:text-xs text-gray-400 line-through mr-1">{{ product.compare_at_price | money }}</span>
                <span class="text-[10px] md:text-xs text-black">{{ product.price | money }}</span>
              {% else %}
                <span class="text-[10px] md:text-xs text-gray-500">{{ product.price | money }}</span>
              {% endif %}
            </div>
          </div>

        </a>
      {% endfor %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [],
  "presets": [
    {
      "name": "Featured Products",
      "category": "Products"
    }
  ]
}
{% endschema %}