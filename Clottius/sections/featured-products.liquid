<section class="bg-white py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-2xl font-bold tracking-widest uppercase text-center mb-12">New Arrivals</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {% for product in collections.all.products limit: 6 %}
        <a href="{{ product.url }}" class="group">
          <div class="overflow-hidden bg-gray-100 aspect-square">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | img_url: '600x600' }}"
                alt="{{ product.title }}"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              >
            {% endif %}
          </div>
          <div class="mt-4">
            <h3 class="text-sm font-medium uppercase tracking-widest">{{ product.title }}</h3>
            <p class="text-sm text-gray-500 mt-1">{{ product.price | money }}</p>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [],
  "presets": [
    {
      "name": "Featured Products",
      "category": "Products"
    }
  ]
}
{% endschema %}