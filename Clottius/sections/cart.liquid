<div class="cart-page">
  <h1 class="cart-page__title">
    {{ 'cart.title' | t }}
  </h1>

  {% if cart.item_count > 0 %}
    <form action="{{ routes.cart_url }}" method="post" class="cart-page__form">

      <div class="cart-page__items">
        {% for item in cart.items %}
          <div class="cart-item">
            <div class="cart-item__image">
              {% render 'image', image: item.image, url: item.url %}
            </div>

            <div class="cart-item__details">
              <div class="cart-item__meta">
                <h3 class="cart-item__title">{{ item.product.title }}</h3>
                {%- unless item.variant.title == 'Default Title' -%}
                  <p class="cart-item__variant">{{ item.variant.title }}</p>
                {%- endunless -%}
              </div>
              <p class="cart-item__price">{{ item.final_line_price | money }}</p>

              <div class="cart-item__actions">
                <input
                  type="number"
                  name="updates[]"
                  value="{{ item.quantity }}"
                  min="0"
                  aria-label="{{ 'cart.quantity' | t }}"
                  class="cart-item__qty"
                >
                <a href="{{ item.url_to_remove }}" class="cart-item__remove">
                  {{ 'cart.remove' | t }}
                </a>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      <div class="cart-page__summary">
        <div class="cart-summary">
          <h2 class="cart-summary__title">{{ 'cart.order_summary' | t }}</h2>

          <div class="cart-summary__row">
            <span class="cart-summary__label">{{ 'cart.subtotal' | t }}</span>
            <span class="cart-summary__value">{{ cart.total_price | money }}</span>
          </div>

          <button type="submit" name="checkout" class="cart-summary__btn-checkout">
            {{ 'cart.checkout' | t }}
          </button>
          <button type="submit" name="update" class="cart-summary__btn-update">
            {{ 'cart.update' | t }}
          </button>

          <p class="cart-summary__note">{{ 'cart.shipping_note' | t }}</p>
        </div>
      </div>

    </form>
  {% else %}
    <div class="cart-empty">
      <p class="cart-empty__text">{{ 'cart.empty' | t }}</p>
      <a href="{{ routes.all_products_collection_url }}" class="cart-empty__link">
        {{ 'cart.continue_shopping' | t }}
      </a>
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .cart-page {
    padding: 5rem var(--page-margin) 4rem;
  }

  .cart-page__title {
    font-size: 1.5rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    margin-bottom: 3rem;
  }

  .cart-page__form {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* Items list */
  .cart-page__items {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .cart-item {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid #f3f4f6;
  }

  .cart-item__image {
    width: 100%;
    height: 16rem;
    background: #f9fafb;
    overflow: hidden;
  }

  .cart-item__image .image {
    height: 100%;
  }

  .cart-item__image .image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-item__details {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cart-item__meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .cart-item__title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .cart-item__variant {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(0, 0, 0, 0.4);
    margin-top: 0.25rem;
  }

  .cart-item__price {
    font-size: 0.75rem;
    font-weight: 500;
  }

  .cart-item__actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .cart-item__qty {
    width: 3rem;
    text-align: center;
    font-size: 0.75rem;
    padding: 0.375rem 0;
    border: 1px solid rgba(0, 0, 0, 0.1);
    outline: none;
    background: transparent;
  }

  .cart-item__remove {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(0, 0, 0, 0.4);
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: color 0.2s;
  }

  .cart-item__remove:hover {
    color: #000;
  }

  /* Summary */
  .cart-summary {
    background: #f9fafb;
    padding: 2rem;
  }

  .cart-summary__title {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    padding-bottom: 1rem;
    border-bottom: 1px solid #e5e7eb;
    margin-bottom: 2rem;
  }

  .cart-summary__row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .cart-summary__label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(0, 0, 0, 0.5);
  }

  .cart-summary__value {
    font-size: 1.125rem;
    font-weight: 700;
  }

  .cart-summary__btn-checkout {
    display: block;
    width: 100%;
    background: #000;
    color: #fff;
    padding: 1.25rem;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
    margin-bottom: 0.75rem;
  }

  .cart-summary__btn-checkout:hover {
    background: #222;
  }

  .cart-summary__btn-update {
    display: block;
    width: 100%;
    background: transparent;
    color: rgba(0, 0, 0, 0.5);
    padding: 0.75rem;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    border: 1px solid rgba(0, 0, 0, 0.1);
    cursor: pointer;
    transition: all 0.2s;
    margin-bottom: 1.5rem;
  }

  .cart-summary__btn-update:hover {
    background: #000;
    color: #fff;
  }

  .cart-summary__note {
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(0, 0, 0, 0.4);
    text-align: center;
    line-height: 1.6;
  }

  /* Empty state */
  .cart-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 5rem 0;
    border-top: 1px solid #f3f4f6;
    gap: 2.5rem;
  }

  .cart-empty__text {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: rgba(0, 0, 0, 0.4);
  }

  .cart-empty__link {
    background: #000;
    color: #fff;
    padding: 1rem 3rem;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .cart-empty__link:hover {
    opacity: 0.8;
  }

  /* Desktop layout */
  @media (min-width: 1024px) {
    .cart-page__title {
      text-align: left;
    }

    .cart-page__form {
      flex-direction: row;
      align-items: flex-start;
      gap: 4rem;
    }

    .cart-page__items {
      flex: 2;
    }

    .cart-item {
      flex-direction: row;
      gap: 2rem;
    }

    .cart-item__image {
      width: 8rem;
      height: 10rem;
      flex-shrink: 0;
    }

    .cart-page__summary {
      flex: 1;
      position: sticky;
      top: 6rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.cart",
  "settings": []
}
{% endschema %}
