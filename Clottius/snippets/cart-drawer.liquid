{% doc %}
  Renders the cart drawer overlay.

  Triggered by clicking the button with id="open-cart" in the header.
  Uses the global `cart` object for initial render.

  @example
  {% render 'cart-drawer' %}
{% enddoc %}

<div id="cart-drawer" role="dialog" aria-modal="true" aria-label="Cart">

  <div id="cart-overlay"></div>

  <div id="cart-panel">

    <div id="cart-panel-header">
      <h2 class="text-sm font-bold uppercase tracking-widest">
        Your Cart
        <span class="text-black/40">({{ cart.item_count }})</span>
      </h2>
      <button id="close-cart" aria-label="Close cart" class="text-xs uppercase tracking-widest text-black/50 hover:opacity-50 transition-opacity duration-200">
        Close
      </button>
    </div>

    <div id="cart-items">
      {% if cart.item_count > 0 %}
        {% for item in cart.items %}
          <div class="flex gap-4">
            <a href="{{ item.url }}" class="cart-item-image bg-gray-50 overflow-hidden flex-shrink-0">
              {{ item.image | image_url: width: 200 | image_tag: class: 'w-full h-full object-cover' }}
            </a>
            <div class="flex-1 flex flex-col justify-between py-1">
              <div>
                <p class="text-xs font-bold uppercase tracking-wide">{{ item.product.title }}</p>
                {%- unless item.variant.title == 'Default Title' -%}
                  <p class="text-xs uppercase tracking-widest text-black/40">{{ item.variant.title }}</p>
                {%- endunless -%}
              </div>
              <div class="flex items-center justify-between">
                <p class="text-xs tracking-wide">{{ item.final_line_price | money }}</p>
                <span class="text-xs text-black/40 uppercase tracking-widest">Qty {{ item.quantity }}</span>
              </div>
            </div>
          </div>
        {% endfor %}
      {% else %}
        <div class="cart-empty">
          <p class="text-xs uppercase tracking-widest text-black/40">Your cart is empty.</p>
        </div>
      {% endif %}
    </div>

    {%- if cart.item_count > 0 -%}
      <div id="cart-panel-footer">
        <div class="flex justify-between items-center mb-5">
          <span class="text-xs uppercase tracking-widest text-black/50">Subtotal</span>
          <span class="text-sm font-bold">{{ cart.total_price | money }}</span>
        </div>
        <a href="{{ routes.checkout_url }}" class="cart-btn-checkout">
          Checkout
        </a>
        <a href="{{ routes.cart_url }}" class="cart-btn-view">
          View Cart
        </a>
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
  #cart-drawer {
    position: fixed;
    inset: 0;
    z-index: 500;
    visibility: hidden;
  }

  #cart-drawer.is-open {
    visibility: visible;
  }

  #cart-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    opacity: 0;
    transition: opacity 0.3s ease;
    cursor: pointer;
  }

  #cart-drawer.is-open #cart-overlay {
    opacity: 1;
  }

  #cart-panel {
    position: absolute;
    top: 0;
    right: 0;
    height: 100%;
    width: 100%;
    max-width: 28rem;
    background: #fff;
    box-shadow: -4px 0 24px rgba(0, 0, 0, 0.08);
    transform: translateX(100%);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  #cart-drawer.is-open #cart-panel {
    transform: translateX(0);
  }

  #cart-panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid #f3f4f6;
  }

  #cart-items {
    flex: 1;
    overflow-y: auto;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .cart-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
  }

  .cart-item-image {
    width: 5rem;
    height: 6rem;
  }

  #cart-panel-footer {
    padding: 1.5rem;
    border-top: 1px solid #f3f4f6;
  }

  .cart-btn-checkout {
    display: block;
    width: 100%;
    background: #000;
    color: #fff;
    text-align: center;
    padding: 1rem;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    text-decoration: none;
    transition: background 0.2s;
  }

  .cart-btn-checkout:hover {
    background: #222;
  }

  .cart-btn-view {
    display: block;
    width: 100%;
    text-align: center;
    padding: 0.75rem;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(0, 0, 0, 0.4);
    text-decoration: none;
    transition: opacity 0.2s;
    margin-top: 0.5rem;
  }

  .cart-btn-view:hover {
    opacity: 0.5;
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    const drawer = document.getElementById('cart-drawer');
    const overlay = document.getElementById('cart-overlay');
    const closeBtn = document.getElementById('close-cart');

    function openCart() {
      drawer.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    }

    function closeCart() {
      drawer.classList.remove('is-open');
      document.body.style.overflow = '';
    }

    window.ClottiusCart = { open: openCart, close: closeCart };

    if (closeBtn) closeBtn.addEventListener('click', closeCart);
    if (overlay) overlay.addEventListener('click', closeCart);

    document.addEventListener('click', function (e) {
      if (e.target.closest('#open-cart')) {
        e.preventDefault();
        openCart();
      }
    });
  })();
{% endjavascript %}
